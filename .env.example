# ==================== Discord ====================
DISCORD_TOKEN=YOUR_BOT_TOKEN_HERE
CLIENT_ID=YOUR_CLIENT_ID_HERE

# Optional: for faster command refresh while testing
GUILD_ID=YOUR_TEST_GUILD_ID_HERE

# Optional: ID kamu sendiri agar bisa bypass akses Admin (meskipun kamu bukan Admin di server)
OWNER_ID=

# ==================== Lavalink ====================
# NOTE: Lavalink server must be running separately (same host or another server).
LAVALINK_NAME=local
LAVALINK_HOST=127.0.0.1
LAVALINK_PORT=2333
LAVALINK_PASSWORD=youshallnotpass
LAVALINK_SECURE=false

# ==================== Optional ====================
# Default volume when player is created
DEFAULT_VOLUME=60

# How long (seconds) bot will wait in voice channel after queue empty (when 24/7 is OFF)
LEAVE_TIMEOUT_SEC=120

# Log level: debug | info | warn | error
LOG_LEVEL=info

# ==================== Prefix Commands ====================
# Prefix untuk text commands (default: .)
# Contoh: .p untuk play, .s untuk skip, .q untuk queue
PREFIX=.

# ==================== Spotify (Optional) ====================
# Get from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ==================== AI Features (Optional) ====================
# NVIDIA API Key untuk fitur AI Playlist Generator (/aiplaylist) & Roast (/roast)
# Get from https://build.nvidia.com/
# Model: qwen/qwen3-next-80b-a3b-instruct
NVIDIA_API_KEY=
